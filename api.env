# Vector 2.0 — Local AI Configuration
# ====================================

# Ollama (LOCAL LLM — primary, free, private)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:4b
# VLM for scene description: llava:7b is purpose-built for image understanding (less hallucination)
# Falls back to gemma3:12b if llava:7b is not yet downloaded
VLM_MODEL=llava:7b

# ChromaDB (LOCAL vector database)
CHROMADB_DIR=./vector_memory_chroma

# Audio source: "vector" uses Vector's built-in microphone array (NOTE: wire-pod
# streams a synthetic test tone — not real audio). "pc" uses the PC microphone.
AUDIO_SOURCE=pc
MICROPHONE_DEVICE_ID=1

# Ambient listening: Vector listens to ALL room speech and decides (via LLM)
# whether to join the conversation — no wake word required.
# Set to "false" to revert to wake-word-only mode ("hey vector" / "ciao vector").
AMBIENT_MODE=true

# Local Whisper STT (faster-whisper, GPU-accelerated)
# tiny/base/small/medium/large-v3 — "small" is a good balance of speed and accuracy
WHISPER_MODEL=small

# Wire-pod bridge: OpenAI-compatible HTTP server that wire-pod's Knowledge Graph calls
# Configure in wire-pod web UI (http://192.168.1.6:8080):
#   Knowledge Graph → Provider: Custom
#   URL: http://<this-PC-IP>:8181
#   Key: local
#   Intent Graph: YES
WIREPOD_BRIDGE_PORT=8181

# Cloud API keys (OPTIONAL — used only as fallback if Ollama is unavailable)
# GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
